@startuml
skinparam componentStyle rectangle

package "Interface Layer" {
  component "User Interface" as UI
  component "Input Validator" as IV
  component "Result Presenter" as RP
}

package "Model Layer" {
  component "Hierarchy Manager" as HM
  component "Conflict Detector" as CD
  component "Completeness Checker" as CC
  component "Physics Engine" as PE
  component "Parameter Estimator" as ParEst
  component "Statistics Evaluator" as StatEval
  component "Compute Runtime" as CR
}

package "Observables Layer" {
  component "Observables Interface" as OI
}

package "Data Layer" {
  component "FITS/HDF5 I/O Manager" as FITSIO
  component "Result Repository" as RR
}

' Interface Layer internal
UI --> IV : User Input Validation

' Input pipeline
IV --> HM : Structured Model

' Model management
HM --> CD : Conflict Detection
HM --> CC : Completeness Check

' Forward path
PE --> CR : Compute Resources
PE --> OI : Forward Pipeline

' Inverse path
ParEst --> CR : Compute Resources
ParEst <-- FITSIO : Inverse Pipeline (format-agnostic)

' Statistics and output
ParEst --> StatEval : Deviance/Posterior
StatEval --> RP : Result Pipeline

' Data Layer internal
OI --> FITSIO : Delegate Serialization/Deserialization
FITSIO --> RR : Persistence/Cache

' Horizontal services
RP ..> FITSIO : Data Service Interface (User Download)

' Resource status
CR ..> UI : Resource Status (Pub-Sub)

@enduml
